# 12-factor: all config via environment. Copy to .env and fill in. Never commit .env.
# Secrets rotation: keys live only here and in the deploy platform's env store.

# LLM provider: gemini (default; AI Studio free tier) or anthropic.
# The agent core is provider-agnostic; this picks the adapter.
LLM_PROVIDER=gemini

# Gemini API key (https://aistudio.google.com/apikey). Free tier is fine for the demo.
GEMINI_API_KEY=

# Anthropic API key (https://platform.claude.com). Only needed if LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Postgres with pgvector. Local dev: docker compose up -d, then this default works.
DATABASE_URL=postgres://plainsheet:plainsheet@localhost:5433/plainsheet

# Model split (cost/latency-aware): fast model for tool steps, stronger model for
# user-facing answers. Defaults per provider live in the provider factory
# (gemini-2.5-flash / gemini-2.5-flash-lite, or claude-sonnet-5 / claude-haiku-4-5).
# Uncomment to override:
# ANSWER_MODEL=
# TOOL_MODEL=

# Pause between eval cases in ms (free-tier RPM headroom). Default 5000 on Gemini.
# EVAL_DELAY_MS=5000

# Agent limits
MAX_AGENT_STEPS=6
