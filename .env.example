# 12-factor: all config via environment. Copy to .env and fill in. Never commit .env.
# Secrets rotation: keys live only here and in the deploy platform's env store.

# Anthropic API key (https://platform.claude.com). Scope: this project only.
ANTHROPIC_API_KEY=

# Postgres with pgvector. Local dev: docker compose up -d, then this default works.
DATABASE_URL=postgres://plainsheet:plainsheet@localhost:5433/plainsheet

# Model split (cost-aware): fast model for tool steps and eval judging,
# stronger model for user-facing answers. IDs current as of Jul 2026.
ANSWER_MODEL=claude-sonnet-5
TOOL_MODEL=claude-haiku-4-5
JUDGE_MODEL=claude-haiku-4-5

# Agent limits
MAX_AGENT_STEPS=6
